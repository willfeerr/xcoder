{
  "name": "@skrbe/xcoder",
  "version": "0.1.0",
  "description": "Agente local de programação conectado ao SkrbeCom Bridge e MCP Gateway.",
  "type": "module",
  "bin": {
    "xcoder": "./dist/cli.js",
    "skrbe-dev-agent": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepare": "npm run build"
  },
  "engines": { "node": ">=20.11" },
  "dependencies": { "ws": "^8.18.3" },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "keywords": ["skrbe", "mcp", "agent", "developer-tools", "automation"],
  "license": "MIT"
}
